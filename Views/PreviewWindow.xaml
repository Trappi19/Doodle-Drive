<ui:FluentWindow x:Class="DoodleDrive.Views.PreviewWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Aperçu"
                 Width="900" Height="680"
                 MinWidth="420" MinHeight="320"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" x:Name="Bar" Title="Aperçu" />

        <Border Grid.Row="1" Background="#20000000" Margin="10" CornerRadius="10">
            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="12" RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>
    </Grid>
</ui:FluentWindow>
