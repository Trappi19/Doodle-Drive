# ============================================================
# Doodle Drive — modèle de configuration privée
# Copie ce fichier en ".env" (non versionné) et remplis tes identifiants.
# Les valeurs définies ici ÉCRASENT la config au démarrage de l'app.
# Laisse une ligne vide/absente pour ne pas surcharger cette valeur.
# ============================================================

# --- Base MariaDB (comptes & permissions) ---
DOODLE_DB_HOST=dalt.freeboxos.fr
DOODLE_DB_PORT=13306
DOODLE_DB_NAME=cloud_perso
DOODLE_DB_USER=
DOODLE_DB_PASSWORD=

# --- Serveur FTP (disque dur sur la Freebox) ---
DOODLE_FTP_HOST=dalt.freeboxos.fr
DOODLE_FTP_PORT=21
DOODLE_FTP_USER=
DOODLE_FTP_PASSWORD=
# Dossier racine du drive sur le disque FTP (ex : /Disque dur)
DOODLE_FTP_ROOT=/
# FTPS (TLS explicite) : true / false
DOODLE_FTP_TLS=false
