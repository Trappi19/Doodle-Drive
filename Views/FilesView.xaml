<UserControl x:Class="DoodleDrive.Views.FilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:DoodleDrive.ViewModels"
             xmlns:models="clr-namespace:DoodleDrive.Models"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:FilesViewModel}"
             d:DesignHeight="600" d:DesignWidth="900"
             PreviewMouseDown="FilesView_OnPreviewMouseDown">

    <UserControl.Resources>
        <!-- Menu contextuel d'un élément (partagé entre vue grille et vue liste).
             L'hôte doit poser Tag = FilesViewModel (DataContext racine). -->
        <ContextMenu x:Key="EntryContextMenu" x:Shared="False">
            <MenuItem Header="Ouvrir / Aperçu"
                      Command="{Binding PlacementTarget.Tag.OpenEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="Télécharger"
                      Command="{Binding PlacementTarget.Tag.DownloadSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="Copier le chemin"
                      Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <Separator />
            <MenuItem Header="Renommer"
                      Command="{Binding PlacementTarget.Tag.RenameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="Supprimer"
                      Command="{Binding PlacementTarget.Tag.DeleteSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <Separator Visibility="{Binding PlacementTarget.DataContext.IsDirectory, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
            <MenuItem Header="Gérer les accès…"
                      Visibility="{Binding PlacementTarget.DataContext.IsDirectory, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}"
                      Command="{Binding PlacementTarget.Tag.ManageAccessForEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>

        <!-- Carte d'un élément en vue grille -->
        <DataTemplate x:Key="GridItemTemplate" DataType="{x:Type vm:FileEntryViewModel}">
            <Border Width="158" Height="150" CornerRadius="10" Margin="6" Padding="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"
                    ContextMenu="{StaticResource EntryContextMenu}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding DataContext.OpenEntryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Style="{StaticResource GlyphText}" Text="{Binding Glyph}" FontSize="46"
                                   Foreground="{Binding AccentBrushKey, Converter={StaticResource KeyToBrush}}"
                                   Visibility="{Binding Thumbnail, Converter={StaticResource NullToVis}, ConverterParameter=invert}" />
                        <Border CornerRadius="8" ClipToBounds="True"
                                Visibility="{Binding Thumbnail, Converter={StaticResource NullToVis}}">
                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                               TextAlignment="Center" Margin="0,8,0,0" MaxHeight="34" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2" Text="{Binding SizeText}" FontSize="11" Opacity="0.6"
                               TextAlignment="Center" Margin="0,2,0,0" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ==================== Barre de commandes ==================== -->
        <Grid Grid.Row="0" Margin="18,14,18,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button Command="{Binding NewFolderCommand}" Appearance="Secondary" Margin="0,0,8,0"
                           IsEnabled="{Binding CanWriteCurrent}" ToolTip="Nouveau dossier">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource GlyphText}" Text="&#xE8F4;" FontSize="15" Margin="0,0,6,0" />
                        <TextBlock Text="Nouveau" />
                    </StackPanel>
                </ui:Button>
                <ui:Button Command="{Binding UploadFilesCommand}" Appearance="Primary" Margin="0,0,8,0"
                           IsEnabled="{Binding CanWriteCurrent}" ToolTip="Envoyer des fichiers">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource GlyphText}" Text="&#xE898;" FontSize="15" Margin="0,0,6,0" />
                        <TextBlock Text="Envoyer" />
                    </StackPanel>
                </ui:Button>
                <ui:Button Command="{Binding DownloadSelectedCommand}" Appearance="Secondary" Margin="0,0,8,0"
                           IsEnabled="{Binding HasSelection}" ToolTip="Télécharger la sélection">
                    <TextBlock Style="{StaticResource GlyphText}" Text="&#xE896;" FontSize="15" />
                </ui:Button>
                <ui:Button Command="{Binding DeleteSelectedCommand}" Appearance="Secondary" Margin="0,0,8,0"
                           IsEnabled="{Binding HasSelection}" ToolTip="Supprimer la sélection">
                    <TextBlock Style="{StaticResource GlyphText}" Text="&#xE74D;" FontSize="15" />
                </ui:Button>
                <ui:Button Command="{Binding ManageAccessCommand}" Appearance="Secondary" Margin="0,0,8,0"
                           IsEnabled="{Binding CanManageCurrent}" ToolTip="Gérer les accès de ce dossier">
                    <TextBlock Style="{StaticResource GlyphText}" Text="&#xE71E;" FontSize="15" />
                </ui:Button>
            </StackPanel>

            <ui:TextBox Grid.Column="1" MaxWidth="320" HorizontalAlignment="Right" Margin="12,0"
                        PlaceholderText="Rechercher dans ce dossier…"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Menu Background="Transparent" VerticalAlignment="Center">
                    <MenuItem ToolTip="Trier">
                        <MenuItem.Header>
                            <TextBlock Style="{StaticResource GlyphText}" Text="&#xE8CB;" FontSize="15" />
                        </MenuItem.Header>
                        <MenuItem Header="Nom" Command="{Binding SetSortCommand}" CommandParameter="Name" />
                        <MenuItem Header="Date de modification" Command="{Binding SetSortCommand}" CommandParameter="Modified" />
                        <MenuItem Header="Taille" Command="{Binding SetSortCommand}" CommandParameter="Size" />
                        <MenuItem Header="Type" Command="{Binding SetSortCommand}" CommandParameter="Kind" />
                    </MenuItem>
                </Menu>
                <ui:Button Command="{Binding ToggleViewCommand}" Appearance="Secondary" Margin="6,0,0,0"
                           ToolTip="Basculer grille / liste">
                    <TextBlock FontSize="15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GlyphText}">
                                <Setter Property="Text" Value="&#xE8FD;" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGridView}" Value="True">
                                        <Setter Property="Text" Value="&#xF0E2;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </ui:Button>
                <ui:Button Command="{Binding RefreshCommand}" Appearance="Secondary" Margin="6,0,0,0" ToolTip="Actualiser">
                    <TextBlock Style="{StaticResource GlyphText}" Text="&#xE72C;" FontSize="15" />
                </ui:Button>
                <ui:Button Command="{Binding SignalUploadPanelCommand}" Appearance="Secondary" Margin="6,0,0,0"
                           ToolTip="File d'attente d'envoi"
                           Visibility="{Binding Uploads.Count, Converter={StaticResource CountToVis}}">
                    <TextBlock Style="{StaticResource GlyphText}" Text="&#xE896;" FontSize="15" />
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- ==================== Fil d'Ariane + accès ==================== -->
        <Grid Grid.Row="1" Margin="18,4,18,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0" Command="{Binding NavigateUpCommand}" Appearance="Transparent"
                       Padding="6" Margin="0,0,4,0" ToolTip="Dossier parent">
                <TextBlock Style="{StaticResource GlyphText}" Text="&#xE72B;" FontSize="15" />
            </ui:Button>

            <ItemsControl Grid.Column="1" ItemsSource="{Binding Breadcrumb}" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BreadcrumbItem}">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding Path}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2">
                                <TextBlock Text="{Binding Name}" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Opacity" Value="0.7" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLast}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                            <TextBlock Text="&#xE76C;" Style="{StaticResource GlyphText}" FontSize="11" Opacity="0.4"
                                       Margin="2,0" VerticalAlignment="Center"
                                       Visibility="{Binding IsLast, Converter={StaticResource InverseBoolToVis}}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Command="{Binding CopyCurrentPathCommand}" Appearance="Transparent"
                           Padding="6" Margin="0,0,6,0" ToolTip="Copier le chemin d'accès">
                    <TextBlock Style="{StaticResource GlyphText}" Text="&#xE8C8;" FontSize="14" />
                </ui:Button>
                <Border CornerRadius="12" Padding="10,3" VerticalAlignment="Center"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource GlyphText}" Text="&#xE72E;" FontSize="12" Margin="0,0,6,0" Opacity="0.7" />
                        <TextBlock Text="{Binding CurrentAccessLabel}" FontSize="12" Opacity="0.85" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ==================== Corps : arbre + contenu ==================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="180" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Arbre des dossiers -->
            <Border Grid.Column="0" Margin="14,0,0,14" CornerRadius="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <TreeView x:Name="FolderTreeView" ItemsSource="{Binding FolderTree}"
                          Background="Transparent" BorderThickness="0" Padding="6"
                          SelectedItemChanged="FolderTreeView_OnSelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="2"
                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Gérer les accès…"
                                                  Command="{Binding PlacementTarget.Tag.ManageAccessForNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Style="{StaticResource GlyphText}" Text="{Binding Glyph}" FontSize="15"
                                           Foreground="{StaticResource KindFolderBrush}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="Transparent" ResizeBehavior="PreviousAndNext" />

            <!-- Zone principale -->
            <Grid Grid.Column="2" Margin="8,0,14,14"
                  AllowDrop="True" Drop="Content_OnDrop" DragOver="Content_OnDragOver" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <Grid x:Name="ContentHost">
                        <!-- Vue grille -->
                        <ListBox x:Name="GridList" ItemsSource="{Binding Entries}"
                                 Background="Transparent" BorderThickness="0" Padding="8"
                                 SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemTemplate="{StaticResource GridItemTemplate}"
                                 Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Vue liste -->
                        <ListView x:Name="DetailList" ItemsSource="{Binding Entries}"
                                  Background="Transparent" BorderThickness="0"
                                  Visibility="{Binding IsGridView, Converter={StaticResource InverseBoolToVis}}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}" />
                                    <Setter Property="ContextMenu" Value="{StaticResource EntryContextMenu}" />
                                    <EventSetter Event="MouseDoubleClick" Handler="DetailItem_OnDoubleClick" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="380" Header="Nom">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource GlyphText}" Text="{Binding Glyph}" FontSize="18"
                                                               Foreground="{Binding AccentBrushKey, Converter={StaticResource KeyToBrush}}"
                                                               Margin="0,0,10,0" />
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="170" Header="Modifié le" DisplayMemberBinding="{Binding ModifiedText}" />
                                    <GridViewColumn Width="110" Header="Taille" DisplayMemberBinding="{Binding SizeText}" />
                                    <GridViewColumn Width="150" Header="Type" DisplayMemberBinding="{Binding KindText}" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- État vide -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding IsEntriesEmpty, Converter={StaticResource BoolToVis}}">
                            <TextBlock Style="{StaticResource GlyphText}" Text="&#xE8B7;" FontSize="52" Opacity="0.25" />
                            <TextBlock Text="{Binding EmptyMessage}" Opacity="0.5" Margin="0,10,0,0" HorizontalAlignment="Center" />
                            <TextBlock Text="Glissez-déposez des fichiers ici pour les envoyer" Opacity="0.4"
                                       FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"
                                       Visibility="{Binding CanWriteCurrent, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <!-- Overlay occupé -->
                        <Border Background="#40000000" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                            <ui:ProgressRing IsIndeterminate="True" Width="46" Height="46" />
                        </Border>
                    </Grid>
                </Border>

                <!-- ==================== Panneau d'envoi ==================== -->
                <Border Grid.Row="1" Margin="0,10,0,0" CornerRadius="10" Padding="14,10"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Visibility="{Binding IsUploadPanelOpen, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="File d'attente d'envoi" FontWeight="SemiBold" />
                            <ui:Button HorizontalAlignment="Right" Appearance="Transparent" Padding="4"
                                       Command="{Binding SignalUploadPanelCommand}">
                                <TextBlock Style="{StaticResource GlyphText}" Text="&#xE711;" FontSize="12" />
                            </ui:Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Uploads}" MaxHeight="160" Margin="0,6,0,0">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:UploadItemViewModel}">
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            <ProgressBar Height="4" Margin="0,3,0,0" Minimum="0" Maximum="100"
                                                         Value="{Binding Progress}" IsIndeterminate="{Binding IsIndeterminate}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="11"
                                                   Opacity="0.7" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
