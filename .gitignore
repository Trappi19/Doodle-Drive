# --- Visual Studio ---
.vs/
*.user
*.suo
*.userprefs
*.rsuser
*.sln.docstates
*.userosscache
*.VC.db
*.VC.VC.opendb

# --- Caches / restauration NuGet ---
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
.nuget/
project.lock.json
project.fragment.lock.json
artifacts/

# --- Rider / ReSharper ---
.idea/
*.sln.iml
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# --- Visual Studio Code ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
