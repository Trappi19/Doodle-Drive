<ui:FluentWindow x:Class="DoodleDrive.Views.Dialogs.InputDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Saisie"
                 Width="440" SizeToContent="Height"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Saisie" ShowMaximize="False" ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="24,12,24,8">
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
            <TextBlock x:Name="MessageText" Margin="0,8,0,10" Opacity="0.8" TextWrapping="Wrap" />
            <ui:TextBox x:Name="ValueBox" MinHeight="38" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,12,24,20">
            <ui:Button Content="Annuler" Appearance="Secondary" IsCancel="True"
                       MinWidth="96" Margin="0,0,10,0" Click="Cancel_OnClick" />
            <ui:Button x:Name="OkButton" Content="Valider" Appearance="Primary"
                       IsDefault="True" MinWidth="96" Click="Ok_OnClick" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
