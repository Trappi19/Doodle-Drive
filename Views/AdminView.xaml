<UserControl x:Class="DoodleDrive.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:DoodleDrive.ViewModels"
             xmlns:models="clr-namespace:DoodleDrive.Models"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:AdminViewModel}"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Administration" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="Comptes utilisateurs et dossiers" Opacity="0.65" />
            </StackPanel>
            <ui:Button HorizontalAlignment="Right" VerticalAlignment="Top" Appearance="Secondary"
                       Command="{Binding RefreshCommand}" ToolTip="Actualiser">
                <TextBlock Style="{StaticResource GlyphText}" Text="&#xE72C;" FontSize="15" />
            </ui:Button>
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- ==================== Utilisateurs ==================== -->
            <TabItem Header="Utilisateurs">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ui:Button Grid.Row="0" HorizontalAlignment="Left" Appearance="Primary" Margin="0,0,0,10"
                               Command="{Binding CreateUserCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource GlyphText}" Text="&#xE710;" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Créer un compte" />
                        </StackPanel>
                    </ui:Button>

                    <Border Grid.Row="1" CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                        <ListView ItemsSource="{Binding Users}" Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="220" Header="Identifiant">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="30" Height="30" CornerRadius="15" Margin="0,0,10,0"
                                                            Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                        <TextBlock Text="{Binding Username}" Foreground="White" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Username}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="130" Header="Rôle">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Left"
                                                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                                    <TextBlock VerticalAlignment="Center" FontSize="12">
                                                        <TextBlock.Text>
                                                            <Binding Path="Role" />
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="160" Header="Créé le"
                                                    DisplayMemberBinding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" />
                                    <GridViewColumn Width="180" Header="Actions">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:Button Appearance="Secondary" Margin="0,0,6,0" ToolTip="Réinitialiser le mot de passe"
                                                               Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                               CommandParameter="{Binding}">
                                                        <TextBlock Style="{StaticResource GlyphText}" Text="&#xE72E;" FontSize="13" />
                                                    </ui:Button>
                                                    <ui:Button Appearance="Secondary" Margin="0,0,6,0" ToolTip="Changer le rôle"
                                                               Command="{Binding DataContext.ToggleRoleCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                               CommandParameter="{Binding}">
                                                        <TextBlock Style="{StaticResource GlyphText}" Text="&#xE748;" FontSize="13" />
                                                    </ui:Button>
                                                    <ui:Button Appearance="Secondary" ToolTip="Supprimer le compte"
                                                               Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                               CommandParameter="{Binding}">
                                                        <TextBlock Style="{StaticResource GlyphText}" Text="&#xE74D;" FontSize="13" />
                                                    </ui:Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ==================== Dossiers ==================== -->
            <TabItem Header="Tous les dossiers">
                <Border Margin="0,12,0,0" CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <ListView ItemsSource="{Binding Folders}" Background="Transparent" BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="200" Header="Nom">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource GlyphText}" Text="&#xE8B7;" FontSize="16"
                                                           Foreground="{StaticResource KindFolderBrush}" Margin="0,0,10,0" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="320" Header="Chemin FTP" DisplayMemberBinding="{Binding FtpPath}" />
                                <GridViewColumn Width="140" Header="Propriétaire" DisplayMemberBinding="{Binding OwnerName}" />
                                <GridViewColumn Width="130" Header="Actions">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:Button Appearance="Secondary" Margin="0,0,6,0" ToolTip="Gérer les accès"
                                                           Command="{Binding DataContext.ManageFolderAccessCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                           CommandParameter="{Binding}">
                                                    <TextBlock Style="{StaticResource GlyphText}" Text="&#xE71E;" FontSize="13" />
                                                </ui:Button>
                                                <ui:Button Appearance="Secondary" ToolTip="Retirer de la base"
                                                           Command="{Binding DataContext.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                           CommandParameter="{Binding}">
                                                    <TextBlock Style="{StaticResource GlyphText}" Text="&#xE74D;" FontSize="13" />
                                                </ui:Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
