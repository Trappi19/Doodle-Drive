<ui:FluentWindow x:Class="DoodleDrive.Views.LoginWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:h="clr-namespace:DoodleDrive.Helpers"
                 xmlns:vm="clr-namespace:DoodleDrive.ViewModels"
                 mc:Ignorable="d"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 d:DataContext="{d:DesignInstance vm:LoginViewModel}"
                 Title="Doodle Drive"
                 Width="480" Height="720"
                 MinWidth="420" MinHeight="560"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 Icon="pack://application:,,,/assets/icon.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Doodle Drive" ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/assets/icon.ico" Width="18" Height="18" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="36,8,36,28">
            <StackPanel MaxWidth="380" VerticalAlignment="Center">

                <Image Source="pack://application:,,,/assets/icon.ico"
                       Width="88" Height="88" Margin="0,8,0,16"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.3" />
                    </Image.Effect>
                </Image>

                <TextBlock Text="Doodle Drive" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="Votre drive personnel sur la Freebox"
                           Opacity="0.7" HorizontalAlignment="Center" Margin="0,2,0,26" />

                <TextBlock Text="Identifiant" Margin="2,0,0,4" FontWeight="SemiBold" />
                <ui:TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Nom d'utilisateur" />

                <TextBlock Text="Mot de passe" Margin="2,14,0,4" FontWeight="SemiBold" />
                <PasswordBox h:PasswordHelper.BindPassword="True"
                             h:PasswordHelper.BoundPassword="{Binding PasswordInput, Mode=TwoWay}"
                             MinHeight="38" />

                <CheckBox Content="Se souvenir de mon identifiant"
                          IsChecked="{Binding RememberMe}" Margin="0,14,0,0" />

                <ui:Button Command="{Binding LoginCommand}" IsDefault="True"
                           Appearance="Primary" HorizontalAlignment="Stretch"
                           Margin="0,20,0,0" Height="42" FontSize="15">
                    <StackPanel Orientation="Horizontal">
                        <ui:ProgressRing Width="18" Height="18" IsIndeterminate="True" Margin="0,0,8,0"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="Se connecter" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>

                <Border Margin="0,16,0,0" Padding="12,10" CornerRadius="8"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                        Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ToastErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <Expander Header="Paramètres serveur (MariaDB &amp; FTP)"
                          IsExpanded="{Binding IsServerPanelOpen}" Margin="0,22,0,0">
                    <Grid Margin="0,10,0,0">
                        <!-- Cadenas : réservé aux administrateurs -->
                        <StackPanel Visibility="{Binding IsServerLocked, Converter={StaticResource BoolToVis}}">
                            <Border CornerRadius="8" Padding="12" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Style="{StaticResource GlyphText}" Text="&#xE72E;" FontSize="16" Margin="0,0,8,0" />
                                        <TextBlock Text="Réglages réservés à l'administrateur" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                                               Text="Saisissez vos identifiants administrateur dans les champs ci-dessus, puis déverrouillez pour modifier la connexion au serveur." />
                                    <ui:Button Command="{Binding UnlockServerCommand}" Appearance="Secondary"
                                               HorizontalAlignment="Stretch" Margin="0,10,0,0" Content="Déverrouiller (admin)" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Réglages serveur (déverrouillés) -->
                        <StackPanel Visibility="{Binding IsServerUnlocked, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Base MariaDB" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding DbHost}" PlaceholderText="Hôte" />
                            <ui:TextBox Grid.Column="2" Text="{Binding DbPort}" PlaceholderText="Port" />
                        </Grid>
                        <ui:TextBox Text="{Binding DbName}" PlaceholderText="Base de données" Margin="0,8,0,0" />
                        <ui:TextBox Text="{Binding DbUser}" PlaceholderText="Utilisateur SQL" Margin="0,8,0,0" />
                        <PasswordBox h:PasswordHelper.BindPassword="True"
                                     h:PasswordHelper.BoundPassword="{Binding DbPassword, Mode=TwoWay}"
                                     MinHeight="38" Margin="0,8,0,0" />

                        <TextBlock Text="Serveur FTP (disque dur)" FontWeight="SemiBold" Margin="0,16,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding FtpHost}" PlaceholderText="Hôte FTP" />
                            <ui:TextBox Grid.Column="2" Text="{Binding FtpPort}" PlaceholderText="Port" />
                        </Grid>
                        <ui:TextBox Text="{Binding FtpUser}" PlaceholderText="Utilisateur FTP" Margin="0,8,0,0" />
                        <PasswordBox h:PasswordHelper.BindPassword="True"
                                     h:PasswordHelper.BoundPassword="{Binding FtpPassword, Mode=TwoWay}"
                                     MinHeight="38" Margin="0,8,0,0" />
                        <ui:TextBox Text="{Binding FtpRootPath}" PlaceholderText="Dossier racine (ex : /Disque dur)" Margin="0,8,0,0" />
                        <CheckBox Content="Utiliser FTPS (TLS explicite)" IsChecked="{Binding FtpUseTls}" Margin="0,10,0,0" />

                        <ui:Button Command="{Binding TestConnectionCommand}"
                                   Content="Tester la connexion" Appearance="Secondary"
                                   HorizontalAlignment="Stretch" Margin="0,14,0,0" />
                        </StackPanel>
                    </Grid>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
