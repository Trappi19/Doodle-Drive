# --- Tests / couverture ---
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info

# --- Divers ---
*.tmp
*.cache
*.log
*.tlog
*.bak
*.swp
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# Spécifique à l'application
# ============================================================
# Identifiants privés (MariaDB / FTP) : jamais dans le dépôt.
.env
!.env.example

# La config runtime est aussi stockée dans %AppData%\DoodleDrive\config.json,
# hors du dépôt. Ne commite JAMAIS d'identifiants en dur dans le code.
